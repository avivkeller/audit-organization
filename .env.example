# Copy to .env and fill in real values.
# Read by @github/local-action (`pnpm local`). Each INPUT_* maps to an action
# input (the env-var name is GitHub Actions' built-in convention).

# --- required -------------------------------------------------------------

# GitHub organization login to audit.
INPUT_ORG=my-org

# PAT or GitHub App installation token with `read:org` + `repo`.
# The default GITHUB_TOKEN is NOT sufficient for org-wide reads.
INPUT_TOKEN=ghp_replace_me

# --- recommended ----------------------------------------------------------

# owner/repo where the org-wide report issue is filed.
# Required when running locally (no Actions context to fall back on).
INPUT_REPORT-REPO=my-org/audits

# Log the report instead of opening/updating an issue. Highly recommended for
# the first local run.
INPUT_DRY-RUN=true

# --- optional -------------------------------------------------------------

# Days of inactivity before a member is reported.
# INPUT_INACTIVITY-DAYS=90

# JSON map of team slug -> "owner/repo" for per-team audits. The mapped repo
# is where each team's report issue is filed.
# INPUT_TEAM-MAP={"infra":"my-org/infra-board","data":"my-org/data-board"}

# Comma-separated owner/repo entries excluded from activity scoring.
# INPUT_IGNORE-REPOSITORIES=my-org/legacy,my-org/private-fork

# Comma-separated logins excluded from the audit.
# INPUT_IGNORE-MEMBERS=svc-deploy,svc-backup

# Comma-separated team slugs. Members of any of these teams are skipped.
# INPUT_IGNORE-TEAMS=alumni,owners

# Also audit outside collaborators (default: false).
# INPUT_INCLUDE-OUTSIDE-COLLABORATORS=false

# Audit logins ending in [bot] (default: false skips them).
# INPUT_INCLUDE-BOTS=false

# Comma-separated allowlist: commit,pr,pr-review,pr-comment,issue,issue-comment.
# Including issue-comment / pr-comment automatically engages comment probing.
# INPUT_INTERACTION-TYPES=commit,pr,pr-review,issue

# Max parallel per-member probes.
# INPUT_CONCURRENCY=5

# --- runtime context (optional) -------------------------------------------

# Set to make context.repo resolve when report-repo is omitted. Mostly useful
# if you want to mirror the GitHub Actions environment locally.
# GITHUB_REPOSITORY=my-org/audits
